{
  "name": "statuspage-embed",
  "description": "Embeddable StatusPage widget for NYU Libraries",
  "scripts": {
    "build": "webpack",
    "build:dev:watch": "NODE_ENV=${NODE_ENV:-development} npm run build -- --mode=development --watch --progress --env DEPLOY_ENV=dev",
    "build:dev": "NODE_ENV=${NODE_ENV:-development} npm run build -- --mode=development --env DEPLOY_ENV=dev",
    "build:stage": "NODE_ENV=${NODE_ENV:-production} npm run build -- --mode=production --env DEPLOY_ENV=staging",
    "build:prod": "NODE_ENV=${NODE_ENV:-production} npm run build -- --mode=production --env DEPLOY_ENV=production",
    "eslint": "eslint . --ext .js,.jsx,.cjs,.mjs",
    "eslint:fix": "npm run eslint -- --fix",
    "test": "vitest"
  },
  "devDependencies": {
    "@babel/core": "7.24.7",
    "@babel/node": "7.24.7",
    "@babel/plugin-proposal-private-methods": "7.18.6",
    "@babel/plugin-transform-runtime": "7.24.7",
    "@babel/preset-env": "7.24.7",
    "@babel/runtime": "7.28.6",
    "@eslint/compat": "2.0.2",
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.7.1",
    "babel-loader": "9.1.3",
    "core-js": "3.37.1",
    "css-loader": "7.1.2",
    "eslint": "^10.0.0",
    "extract-loader": "5.0.1",
    "file-loader": "6.0.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "jsdom": "24.1.0",
    "sass": "1.77.6",
    "sass-loader": "14.2.1",
    "vitest": "4.0.18",
    "webpack": "5.92.1",
    "webpack-cli": "5.1.4"
  },
  "resolutions": {
    "y18n": "5.0.8",
    "meow": "13.2.0"
  }
}
